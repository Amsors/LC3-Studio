if(NOT DEFINED EXAMPLES_DIR)
    message(FATAL_ERROR "EXAMPLES_DIR is required")
endif()

if(NOT DEFINED OUTPUT)
    message(FATAL_ERROR "OUTPUT is required")
endif()

function(cpp_escape input output_var)
    set(text "${input}")
    string(REPLACE "\\" "\\\\" text "${text}")
    string(REPLACE "\"" "\\\"" text "${text}")
    string(REPLACE "\n" "\\n" text "${text}")
    set(${output_var} "${text}" PARENT_SCOPE)
endfunction()

function(example_id stem output_var)
    string(TOLOWER "${stem}" id)
    string(REGEX REPLACE "[^a-z0-9]+" "_" id "${id}")
    string(REGEX REPLACE "^_+|_+$" "" id "${id}")
    if(id STREQUAL "")
        set(id "example")
    endif()
    if(NOT id MATCHES "^[a-z_]")
        set(id "example_${id}")
    endif()
    set(${output_var} "${id}" PARENT_SCOPE)
endfunction()

function(default_title stem output_var)
    string(REGEX REPLACE "[-_]+" " " title "${stem}")
    string(STRIP "${title}" title)
    if(title STREQUAL "")
        set(title "Example")
    endif()
    set(${output_var} "${title}" PARENT_SCOPE)
endfunction()

function(raw_string_delimiter content index output_var)
    set(suffix 0)
    set(found_delimiter "")
    while(found_delimiter STREQUAL "")
        set(delimiter "LC3_EXAMPLE_${index}_${suffix}")
        string(FIND "${content}" ")${delimiter}\"" delimiter_pos)
        if(delimiter_pos EQUAL -1)
            set(found_delimiter "${delimiter}")
        else()
            math(EXPR suffix "${suffix} + 1")
        endif()
    endwhile()
    set(${output_var} "${found_delimiter}" PARENT_SCOPE)
endfunction()

if(DEFINED EXAMPLE_FILES)
    set(example_files ${EXAMPLE_FILES})
else()
    file(GLOB example_files "${EXAMPLES_DIR}/*.asm")
endif()
list(SORT example_files)

set(output_text "// This file is generated by tools/embed_examples.cmake.\n")
string(APPEND output_text "// Edit examples/*.asm instead of editing this file.\n\n")
string(APPEND output_text "#include \"src/examples/embedded_examples.h\"\n\n")
string(APPEND output_text "#include <cstddef>\n\n")
string(APPEND output_text "namespace embedded_examples {\n")

list(LENGTH example_files example_count)
if(example_count GREATER 0)
    string(APPEND output_text "namespace {\n\n")
    string(APPEND output_text "constexpr AssemblyExample kExamples[] = {\n")

    set(used_ids "")
    set(index 0)
    foreach(example_file IN LISTS example_files)
        file(READ "${example_file}" content)
        string(REPLACE "\r\n" "\n" content "${content}")
        string(REPLACE "\r" "\n" content "${content}")

        get_filename_component(stem "${example_file}" NAME_WE)
        default_title("${stem}" title)
        set(description "")

        set(title_match "")
        string(REGEX MATCH "(^|\n)[^\n]*name[ \t]*:[ \t]*([^\n]+)" title_match "${content}")
        if(NOT title_match STREQUAL "")
            set(title "${CMAKE_MATCH_2}")
            string(STRIP "${title}" title)
        endif()
        set(description_match "")
        string(REGEX MATCH "(^|\n)[^\n]*description[ \t]*:[ \t]*([^\n]+)" description_match "${content}")
        if(NOT description_match STREQUAL "")
            set(description "${CMAKE_MATCH_2}")
            string(STRIP "${description}" description)
        endif()

        example_id("${stem}" base_id)
        set(id "${base_id}")
        set(id_suffix 2)
        list(FIND used_ids "${id}" id_index)
        while(NOT id_index EQUAL -1)
            set(id "${base_id}_${id_suffix}")
            math(EXPR id_suffix "${id_suffix} + 1")
            list(FIND used_ids "${id}" id_index)
        endwhile()
        list(APPEND used_ids "${id}")

        cpp_escape("${id}" escaped_id)
        cpp_escape("${title}" escaped_title)
        cpp_escape("${description}" escaped_description)
        raw_string_delimiter("${content}" "${index}" delimiter)

        string(APPEND output_text "    {\n")
        string(APPEND output_text "        \"${escaped_id}\",\n")
        string(APPEND output_text "        \"${escaped_title}\",\n")
        string(APPEND output_text "        \"${escaped_description}\",\n")
        string(APPEND output_text "        R\"${delimiter}(${content})${delimiter}\"\n")
        string(APPEND output_text "    },\n")

        math(EXPR index "${index} + 1")
    endforeach()

    string(APPEND output_text "};\n\n")
    string(APPEND output_text "} // namespace\n\n")
    string(APPEND output_text "const AssemblyExample* examples() {\n")
    string(APPEND output_text "    return kExamples;\n")
    string(APPEND output_text "}\n\n")
    string(APPEND output_text "std::size_t exampleCount() {\n")
    string(APPEND output_text "    return sizeof(kExamples) / sizeof(kExamples[0]);\n")
    string(APPEND output_text "}\n")
else()
    string(APPEND output_text "\n")
    string(APPEND output_text "const AssemblyExample* examples() {\n")
    string(APPEND output_text "    return nullptr;\n")
    string(APPEND output_text "}\n\n")
    string(APPEND output_text "std::size_t exampleCount() {\n")
    string(APPEND output_text "    return 0;\n")
    string(APPEND output_text "}\n")
endif()

string(APPEND output_text "\n")
string(APPEND output_text "const AssemblyExample* exampleAt(std::size_t index) {\n")
string(APPEND output_text "    return index < exampleCount() ? examples() + index : nullptr;\n")
string(APPEND output_text "}\n\n")
string(APPEND output_text "const AssemblyExample* findExample(const std::string& id) {\n")
string(APPEND output_text "    for (std::size_t i = 0; i < exampleCount(); i++) {\n")
string(APPEND output_text "        const AssemblyExample* example = exampleAt(i);\n")
string(APPEND output_text "        if (example && id == example->id) {\n")
string(APPEND output_text "            return example;\n")
string(APPEND output_text "        }\n")
string(APPEND output_text "    }\n")
string(APPEND output_text "    return nullptr;\n")
string(APPEND output_text "}\n\n")
string(APPEND output_text "} // namespace embedded_examples\n")

get_filename_component(output_dir "${OUTPUT}" DIRECTORY)
file(MAKE_DIRECTORY "${output_dir}")

if(EXISTS "${OUTPUT}")
    file(READ "${OUTPUT}" existing_text)
    if(existing_text STREQUAL output_text)
        return()
    endif()
endif()

file(WRITE "${OUTPUT}" "${output_text}")
